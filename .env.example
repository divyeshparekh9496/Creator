# Google GenAI API Key (from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_api_key_here

# Google Cloud Project (for Vertex AI / GCS)
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# Google Cloud Storage bucket for Creator assets
GCS_BUCKET_NAME=creator-anime-assets

# Optional: path to service account JSON (for GCS auth)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Note: Free tier = 20 requests/day per model. Creator uses gemini-2.5-flash (text)
# and falls back to gemini-2.0-flash, gemini-1.5-flash on quota. Enable billing for higher limits.
